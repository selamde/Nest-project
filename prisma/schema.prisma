generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model applicant {
  id       String  @id @default(cuid())
  fullName String
  email    String  @unique
  password String
  phone    String?

  notes  String?
  track  Track
  status Status  @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  PENDING
  ACCEPTED
  REJECTED
  SHORTLISTED
}

enum Track {
  FRONTEND
  BACKEND
  UI_UX
  MOBILE
}
